# ── Database ────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rcs
POSTGRES_USER=rcs_user
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO ────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rcs-assets
MINIO_USE_SSL=false

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=replace-with-strong-secret-min-32-chars
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace-with-another-strong-secret

# ── Backend ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Sessions Playwright ──────────────────────────────
SESSIONS_DIR=/data/sessions

# ── Limites ──────────────────────────────────────────
MAX_NUMBERS_PER_ORG=10
BROWSER_IDLE_TTL_MS=600000
