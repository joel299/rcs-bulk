# ── Database ────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rcs
POSTGRES_USER=rcs_user
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MinIO ────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rcs-assets
MINIO_USE_SSL=false

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=replace-with-strong-secret-min-32-chars
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace-with-another-strong-secret

# ── Backend ──────────────────────────────────────────
PORT=3002
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Sessions Playwright ──────────────────────────────
SESSIONS_DIR=/tmp/rcs-sessions

# Playwright (headless dispatch, debug lento, Chrome do sistema opcional)
PLAYWRIGHT_HEADLESS=true
# true = tenta QR em headless (geralmente precisa false para escanear)
PLAYWRIGHT_AUTH_HEADLESS=false
PLAYWRIGHT_SLOW_MO=0
CHROME_EXECUTABLE_PATH=

# ── Limites ──────────────────────────────────────────
MAX_NUMBERS_PER_ORG=10
BROWSER_IDLE_TTL_MS=600000
